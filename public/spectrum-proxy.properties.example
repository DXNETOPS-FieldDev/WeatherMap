# ============================================================================
# Spectrum proxy configuration — read by spectrum-proxy.jsp at startup.
#
# To use: copy this file to `spectrum-proxy.properties` (in the same
# directory) and fill in the values for your environment. The real file
# is gitignored so credentials never end up in source control.
#
# Tomcat must be restarted (or the JSP recompiled) for changes to take effect.
# ============================================================================

# Spectrum REST base URL. Must end with a trailing slash.
# Example: https://your-spectrum.example.com:8443/spectrum/
spectrum.base.url=https://CHANGE-ME-spectrum-host:8443/spectrum/

# Spectrum credentials. The proxy never sends these to the browser — it
# uses them server-side to build a Basic auth header for upstream requests.
#
# On first request, the JSP rewrites the password line with an {obfuscated}
# prefix (so it isn't sitting in plaintext on disk). The prefix tells the
# JSP on subsequent loads to decode the value rather than treat it as raw.
# To rotate the password, just replace the value (with or without prefix)
# and restart Tomcat — the JSP re-obfuscates on the next request.
spectrum.user=CHANGE-ME
spectrum.password=CHANGE-ME

# Disable upstream SSL verification (true for self-signed dev certs).
# For production, install the Spectrum cert in Tomcat's truststore and
# set this to false.
spectrum.ssl.verify=false
